   "source": [
    "# Chapter 1: Introduction — Pluto's First Doubt\n",
    "\n",
    "Demonstrates dead-reckoning drift: why we NEED probabilistic reasoning.\n",
    "Pluto stands still but accumulated sensor noise makes it \"think\" it moved."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "np.random.seed(0)\n",
    "\n",
    "dt = 0.1\n",
    "T = 60.0\n",
    "steps = int(T / dt)\n",
    "\n",
    "# True position (robot stands still)\n",
    "true_pos = np.zeros((steps, 2))\n",
    "\n",
    "# Dead-reckoning with noisy encoders + IMU\n",
    "ENCODER_NOISE = 0.005   # m/step std dev\n",
    "IMU_NOISE = 0.002       # rad/step std dev\n",
    "\n",
    "dr_pos = np.zeros((steps, 2))\n",
    "dr_theta = 0.0\n",
    "\n",
    "for i in range(1, steps):\n",
    "    # Noisy velocity (commanded = 0, but encoder reads non-zero drift)\n",
    "    v_noise = np.random.normal(0, ENCODER_NOISE)\n",
    "    omega_noise = np.random.normal(0, IMU_NOISE)\n",
    "    \n",
    "    dr_theta += omega_noise\n",
    "    dr_pos[i, 0] = dr_pos[i-1, 0] + v_noise * np.cos(dr_theta)\n",
    "    dr_pos[i, 1] = dr_pos[i-1, 1] + v_noise * np.sin(dr_theta)\n",
    "\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(13, 5))\n",
    "fig.suptitle(\"Pluto's First Doubt — Dead-Reckoning Drift (robot stands still)\", fontsize=13)\n",
    "\n",
    "time_axis = np.arange(steps) * dt\n",
    "ax1.plot(time_axis, dr_pos[:, 0], 'steelblue', label='DR position x')\n",
    "ax1.plot(time_axis, dr_pos[:, 1], 'coral', label='DR position y')\n",
    "ax1.axhline(0, color='k', linestyle='--', label='True position')\n",
    "ax1.set_xlabel('Time [s]')\n",
    "ax1.set_ylabel('Position [m]')\n",
    "ax1.set_title('Position Drift Over Time')\n",
    "ax1.legend()\n",
    "ax1.grid(True, alpha=0.3)\n",
    "\n",
    "ax2.plot(dr_pos[:, 0], dr_pos[:, 1], 'steelblue', lw=1.5, label='Pluto thinks it went here')\n",
    "ax2.plot(0, 0, 'g*', markersize=14, zorder=10, label='True position')\n",
    "ax2.set_xlabel('x [m]')\n",
    "ax2.set_ylabel('y [m]')\n",
    "ax2.set_title(f'Path in 2D (after {T:.0f}s at rest)')\n",
    "ax2.set_aspect('equal')\n",
    "ax2.legend()\n",
    "ax2.grid(True, alpha=0.3)\n",
    "\n",
    "drift = np.sqrt(dr_pos[-1, 0]**2 + dr_pos[-1, 1]**2)\n",
    "print(f'After {T:.0f}s standing still, Pluto thinks it is {drift:.3f}m away from start.')\n",
    "print('This is WHY we need a probabilistic framework!')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('ch01_dead_reckoning.png', dpi=120)\n",
    "plt.show()"
   ]
  }
 ],
