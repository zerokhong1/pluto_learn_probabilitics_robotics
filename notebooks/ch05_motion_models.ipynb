   "source": [
    "# Chapter 5: Robot Motion\n",
    "## Banana Distribution — Velocity vs Odometry Motion Model\n",
    "\n",
    "Visualize how `α1..α6` parameters shape the predicted pose distribution."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys, os\n",
    "sys.path.insert(0, os.path.abspath('../src'))\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from pluto_filters.pluto_filters.motion_models.velocity_motion_model import (\n",
    "    sample_motion_model_velocity\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "np.random.seed(42)\n",
    "start = np.array([0.0, 0.0, 0.0])\n",
    "N = 1000\n",
    "\n",
    "# Compare different noise levels\n",
    "configs = [\n",
    "    ('Low noise',    [0.01, 0.001, 0.001, 0.01, 0.0001, 0.0001]),\n",
    "    ('Default',      [0.1,  0.01,  0.01,  0.1,  0.001,  0.001 ]),\n",
    "    ('High noise',   [0.4,  0.05,  0.05,  0.4,  0.01,   0.01  ]),\n",
    "]\n",
    "\n",
    "v, omega, dt = 0.5, 0.05, 2.0\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
    "fig.suptitle(f'Banana Distribution: v={v}, ω={omega}, dt={dt}s', fontsize=13)\n",
    "\n",
    "for ax, (label, alphas) in zip(axes, configs):\n",
    "    samples = np.array([sample_motion_model_velocity(start, v, omega, dt, alphas) for _ in range(N)])\n",
    "    ax.scatter(samples[:, 0], samples[:, 1], alpha=0.3, s=8, c='#F4A700')\n",
    "    ax.plot(0, 0, 'k^', markersize=10, label='Start')\n",
    "    ax.set_title(f'{label}\\nstd_x={samples[:,0].std():.3f}m')\n",
    "    ax.set_aspect('equal')\n",
    "    ax.set_xlabel('x [m]')\n",
    "    ax.set_ylabel('y [m]')\n",
    "    ax.grid(True, alpha=0.3)\n",
    "    ax.legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('ch05_banana.png', dpi=120)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Motion Model Probability\n",
    "Plot `p(x' | u, x)` as a heatmap to see the shape of the density."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from pluto_filters.pluto_filters.motion_models.velocity_motion_model import motion_model_velocity\n",
    "\n",
    "grid_x = np.linspace(-1, 3, 80)\n",
    "grid_y = np.linspace(-2, 2, 80)\n",
    "XX, YY = np.meshgrid(grid_x, grid_y)\n",
    "\n",
    "start_pose = np.array([0.0, 0.0, 0.0])\n",
    "ZZ = np.zeros_like(XX)\n",
    "\n",
    "for i in range(XX.shape[0]):\n",
    "    for j in range(XX.shape[1]):\n",
    "        x_prime = np.array([XX[i, j], YY[i, j], 0.0])\n",
    "        ZZ[i, j] = motion_model_velocity(x_prime, start_pose, 0.5, 0.05, 1.0)\n",
    "\n",
    "plt.figure(figsize=(8, 6))\n",
    "plt.contourf(XX, YY, ZZ, levels=30, cmap='YlOrRd')\n",
    "plt.colorbar(label='p(x\\' | u, x)')\n",
    "plt.plot(0, 0, 'b^', markersize=10, label='Start x')\n",
    "plt.title('Motion Model Probability Density')\n",
    "plt.xlabel('x [m]')\n",
    "plt.ylabel('y [m]')\n",
    "plt.legend()\n",
    "plt.savefig('ch05_motion_prob.png', dpi=120)\n",
    "plt.show()"
   ]
  }
 ],
 "metadata": {\n  \"kernelspec\": {\"display_name\": \"Python 3\", \"language\": \"python\", \"name\": \"python3\"},\n  \"language_info\": {\"name\": \"python\", \"version\": \"3.12.0\"}\n },\n \"nbformat\": 4,\n \"nbformat_minor\": 4\n}\n