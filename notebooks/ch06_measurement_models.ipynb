   "source": [
    "# Chapter 6: Robot Perception — Measurement Models\n",
    "## Beam Model (4 components) vs Likelihood Field\n",
    "\n",
    "Visualize the 4 components of the beam model and how the likelihood field\n",
    "is derived from the occupancy map."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys, os\n",
    "sys.path.insert(0, os.path.abspath('../src'))\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "from pluto_filters.pluto_filters.measurement_models.beam_model import (\n",
    "    BeamModelParams, p_hit, p_short, p_max, p_rand\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# Visualize 4-component beam model\n",
    "# ============================================================\n",
    "params = BeamModelParams()\n",
    "z_star = 4.0  # expected range [m]\n",
    "z_vals = np.linspace(0, params.z_max, 500)\n",
    "\n",
    "ph = np.array([p_hit(z, z_star, params) for z in z_vals])\n",
    "ps = np.array([p_short(z, z_star, params) for z in z_vals])\n",
    "pm = np.array([p_max(z, params) for z in z_vals])\n",
    "pr = np.array([p_rand(z, params) for z in z_vals])\n",
    "\n",
    "total = params.z_hit * ph + params.z_short * ps + params.z_max_w * pm + params.z_rand * pr\n",
    "\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "ax1.plot(z_vals, ph, 'g-', label=f'p_hit (w={params.z_hit})', lw=2)\n",
    "ax1.plot(z_vals, ps, 'darkorange', label=f'p_short (w={params.z_short})', lw=2)\n",
    "ax1.plot([params.z_max, params.z_max], [0, 1], 'r-', label=f'p_max (w={params.z_max_w})', lw=3)\n",
    "ax1.plot(z_vals, pr, 'purple', label=f'p_rand (w={params.z_rand})', lw=2, linestyle='--')\n",
    "ax1.axvline(z_star, color='k', linestyle=':', alpha=0.5, label=f'z* = {z_star}m')\n",
    "ax1.set_title('4 Components of Beam Model')\n",
    "ax1.set_xlabel('z (measured range) [m]')\n",
    "ax1.set_ylabel('p(z | x, m)')\n",
    "ax1.legend()\n",
    "ax1.grid(True, alpha=0.3)\n",
    "\n",
    "ax2.fill_between(z_vals, total, alpha=0.6, color='steelblue')\n",
    "ax2.plot(z_vals, total, 'steelblue', lw=2)\n",
    "ax2.axvline(z_star, color='k', linestyle=':', alpha=0.5, label=f'z* = {z_star}m')\n",
    "ax2.set_title('Total Mixture p(z | x, m)')\n",
    "ax2.set_xlabel('z [m]')\n",
    "ax2.set_ylabel('p(z | x, m)')\n",
    "ax2.legend()\n",
    "ax2.grid(True, alpha=0.3)\n",
    "\n",
    "plt.suptitle('Beam Model — 4 Component Mixture', fontsize=14)\n",
    "plt.tight_layout()\n",
    "plt.savefig('ch06_beam_model.png', dpi=120)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# Likelihood Field from simple occupancy map\n",
    "# ============================================================\n",
    "from pluto_filters.pluto_filters.measurement_models.likelihood_field import LikelihoodField\n",
    "\n",
    "# Build a simple 40x40 room with walls\n",
    "occ = np.zeros((40, 40), dtype=np.int8)\n",
    "occ[0, :] = occ[-1, :] = occ[:, 0] = occ[:, -1] = 100  # walls\n",
    "occ[15:25, 15:20] = 100  # obstacle in room\n",
    "\n",
    "lf = LikelihoodField(occ, resolution=0.2, origin=(-4.0, -4.0))\n",
    "\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(12, 5))\n",
    "\n",
    "ax1.imshow(occ, cmap='binary', origin='lower')\n",
    "ax1.set_title('Occupancy Map')\n",
    "ax1.set_xlabel('cell x')\n",
    "ax1.set_ylabel('cell y')\n",
    "\n",
    "im = ax2.imshow(lf.likelihood, cmap='hot', origin='lower', vmin=0)\n",
    "plt.colorbar(im, ax=ax2, label='Likelihood')\n",
    "ax2.set_title('Likelihood Field (σ=0.2m)')\n",
    "ax2.set_xlabel('cell x')\n",
    "ax2.set_ylabel('cell y')\n",
    "\n",
    "plt.suptitle('Likelihood Field from Occupancy Map', fontsize=13)\n",
    "plt.tight_layout()\n",
    "plt.savefig('ch06_likelihood_field.png', dpi=120)\n",
    "plt.show()\n",
    "print('Hot = high likelihood (near walls/obstacles), Black = low likelihood (open space)')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Exercises\n",
