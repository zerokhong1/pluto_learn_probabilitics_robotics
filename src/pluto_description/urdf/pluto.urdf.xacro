<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="pluto">

  <!-- Constants -->
  <xacro:property name="body_radius" value="0.15"/>
  <xacro:property name="body_height" value="0.60"/>
  <xacro:property name="wheel_radius" value="0.07"/>
  <xacro:property name="wheel_width" value="0.04"/>
  <xacro:property name="wheel_separation" value="0.34"/>
  <xacro:property name="horn_length" value="0.25"/>
  <xacro:property name="horn_radius" value="0.025"/>

  <!-- Materials -->
  <material name="dark_metal">
    <color rgba="0.3 0.32 0.35 1.0"/>
  </material>
  <material name="silver_metal">
    <color rgba="0.75 0.78 0.82 1.0"/>
  </material>
  <material name="eye_default">
    <color rgba="0.0 0.5 1.0 1.0"/>
  </material>
  <material name="wheel_mat">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>
  <material name="chest_panel">
    <color rgba="0.05 0.15 0.35 0.9"/>
  </material>

  <!-- =============================== BASE LINK =============================== -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- Main body -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${body_height/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${body_radius}" length="${body_height}"/>
      </geometry>
      <material name="dark_metal"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${body_height/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${body_radius}" length="${body_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.35" iyy="0.35" izz="0.12" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Chest panel display -->
  <link name="chest_panel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.22 0.02 0.18"/>
      </geometry>
      <material name="chest_panel"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="chest_panel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="chest_panel"/>
    <origin xyz="${body_radius} 0 ${body_height * 0.45}" rpy="0 0 0"/>
  </joint>

  <!-- =============================== HEAD =============================== -->
  <link name="head_link">
    <visual>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.13"/>
      </geometry>
      <material name="silver_metal"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.13"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="head_joint" type="fixed">
    <parent link="base_link"/>
    <child link="head_link"/>
    <origin xyz="0 0 ${body_height}" rpy="0 0 0"/>
  </joint>

  <!-- =============================== HORNS =============================== -->
  <!-- Left horn (LiDAR mount) -->
  <link name="left_horn">
    <visual>
      <origin xyz="0 0 ${horn_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${horn_radius}" length="${horn_length}"/>
      </geometry>
      <material name="dark_metal"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${horn_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${horn_radius}" length="${horn_length}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="left_horn_joint" type="fixed">
    <parent link="head_link"/>
    <child link="left_horn"/>
    <origin xyz="-0.06 0.06 0.12" rpy="0 ${-pi/8} ${pi/6}"/>
  </joint>

  <!-- Right horn (Camera mount) -->
  <link name="right_horn">
    <visual>
      <origin xyz="0 0 ${horn_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${horn_radius}" length="${horn_length}"/>
      </geometry>
      <material name="dark_metal"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${horn_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${horn_radius}" length="${horn_length}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_horn_joint" type="fixed">
    <parent link="head_link"/>
    <child link="right_horn"/>
    <origin xyz="-0.06 -0.06 0.12" rpy="0 ${-pi/8} ${-pi/6}"/>
  </joint>

  <!-- =============================== EYES =============================== -->
  <link name="left_eye">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
      <material name="eye_default"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="left_eye_joint" type="fixed">
    <parent link="head_link"/>
    <child link="left_eye"/>
    <origin xyz="0.10 0.05 0.07" rpy="0 0 0"/>
  </joint>

  <link name="right_eye">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
      <material name="eye_default"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_eye_joint" type="fixed">
    <parent link="head_link"/>
    <child link="right_eye"/>
    <origin xyz="0.10 -0.05 0.07" rpy="0 0 0"/>
  </joint>

  <!-- =============================== WHEELS =============================== -->
  <!-- Left wheel -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_mat"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.002" iyy="0.002" izz="0.004" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 ${wheel_separation/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Right wheel -->
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_mat"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.002" iyy="0.002" izz="0.004" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 ${-wheel_separation/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Caster wheel (passive) -->
  <link name="caster_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${wheel_radius/2}"/>
      </geometry>
      <material name="wheel_mat"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${wheel_radius/2}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0003" iyy="0.0003" izz="0.0003" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="${-body_radius + 0.04} 0 ${-wheel_radius/2}" rpy="0 0 0"/>
  </joint>

  <!-- =============================== SENSORS =============================== -->
  <!-- LiDAR frame (on left horn tip) -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
      <material name="dark_metal"/>
    </visual>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="left_horn"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 ${horn_length}" rpy="0 0 0"/>
  </joint>

  <!-- Camera frame (on right horn tip) -->
  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.06 0.04"/>
      </geometry>
      <material name="dark_metal"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="right_horn"/>
    <child link="camera_link"/>
    <origin xyz="0 0 ${horn_length}" rpy="0 0 0"/>
  </joint>

  <!-- IMU link -->
  <link name="imu_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.00001" iyy="0.00001" izz="0.00001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 ${body_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- =============================== GAZEBO PLUGINS =============================== -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_diameter>${wheel_radius * 2}</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <odometry_topic>odom</odometry_topic>
      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
    </plugin>
  </gazebo>

  <gazebo reference="lidar_link">
    <sensor name="lidar" type="ray">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-${pi}</min_angle>
            <max_angle>${pi}</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="laser_controller" filename="libgazebo_ros_ray_sensor.so">
        <topicName>scan</topicName>
        <frameName>lidar_link</frameName>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="imu_link">
    <sensor name="imu" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <topicName>imu</topicName>
        <frameName>imu_link</frameName>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Body color in Gazebo -->
  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="head_link">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="left_eye">
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo reference="right_eye">
    <material>Gazebo/Blue</material>
  </gazebo>

</robot>
